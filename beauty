function appendMsg(role, text, save){
  var msgs = document.getElementById('msgs'); if(!msgs) return;
  var now = new Date().toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
  var d = document.createElement('div');
  d.className='msg '+(role==='u'||role==='user'?'u':'a');
  d.innerHTML='<div class="mb">'+text.replace(/\n/g,'<br>')+'</div><div class="mt">'+now+'</div>';
  msgs.appendChild(d); msgs.scrollTop=msgs.scrollHeight;
  if(save!==false){
    chatHist.push({role:role,content:text});
    if(chatHist.length>60) chatHist.shift();
    lsSet('bv3_chat',chatHist);
  }
}
function appendTyping(){
  var msgs=document.getElementById('msgs'); if(!msgs) return '';
  var id='ty'+Date.now();
  var d=document.createElement('div'); d.className='msg a'; d.id=id;
  d.innerHTML='<div class="mb"><div class="ty"><div class="td"></div><div class="td"></div><div class="td"></div></div></div>';
  msgs.appendChild(d); msgs.scrollTop=msgs.scrollHeight; return id;
}

async function sendMsg(){
  var inp=document.getElementById('co-inp');
  var msg=inp.value.trim(); if(!msg) return;
  appendMsg('u',msg); inp.value='';
  var tid=appendTyping();
  var stats='Tasks: '+tasks.length+' total, '+tasks.filter(function(t){return t.status==='Done';}).length+' done, '+tasks.filter(isUrgent).length+' urgent.';
  try{
    var res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,
        system:SYS+'\n\n'+stats,
        messages:chatHist.slice(-20).map(function(m){return{role:(m.role==='u'||m.role==='user')?'user':'assistant',content:m.content};})
      })
    });
    var data=await res.json();
    var el=document.getElementById(tid); if(el) el.remove();
    var reply=(data.content||[]).map(function(b){return b.text||'';}).join('')||'Try again in a moment.';
    appendMsg('a',reply);
  }catch(e){
    var el=document.getElementById(tid); if(el) el.remove();
    appendMsg('a','Connection issue — please try again.');
  }
}

document.getElementById('co-send-btn').addEventListener('click', sendMsg);
