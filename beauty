function renderMonth(){
  var mName = new Date().toLocaleDateString('en-US',{month:'long'});
  var mt = tasks.filter(function(t){ return t.month===mName; });
  var now = new Date();
  var bins = [
    {l:'Urgent / This Week', f:function(t){ return isUrgent(t)&&t.status!=='Done'; }},
    {l:'Week 2', f:function(t){ if(!t.due)return false; var dn=(new Date(t.due)-now)/86400000; return dn>7&&dn<=14; }},
    {l:'Week 3', f:function(t){ if(!t.due)return false; var dn=(new Date(t.due)-now)/86400000; return dn>14&&dn<=21; }},
    {l:'Week 4+', f:function(t){ if(!t.due)return false; var dn=(new Date(t.due)-now)/86400000; return dn>21; }},
    {l:'Ongoing', f:function(t){ return !t.due; }},
  ];
  var html = '';
  bins.forEach(function(b){
    var bt = mt.filter(b.f);
    if(!bt.length) return;
    html += '<div class="wh">'+b.l+'</div>'+bt.map(taskHTML).join('');
  });
  var el = document.getElementById('month-list');
  el.innerHTML = html || '<div style="text-align:center;padding:36px;color:var(--st);font-size:13px;">No tasks this month</div>';
  bindTaskEvents(el);
}

// ── TRACK ────────────────────────────────────────────────
function renderTrack(){
  document.getElementById('meas-month').textContent = new Date().toLocaleDateString('en-US',{month:'long',year:'numeric'});
  renderMeasDisplay();
  renderPhotoGrid('ph-body', 'body', PH_MONTHS, 'port');
