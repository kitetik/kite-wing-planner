// ── GANTT ────────────────────────────────────────────────
function renderGantt(){
  var density = WEEKS.map(function(w){
    var we = new Date(w); we.setDate(we.getDate()+6);
    return tasks.filter(function(t){
      if(!t.due) return false;
      var d = new Date(t.due); return d>=w&&d<=we;
    }).length;
  });
  var maxD = Math.max.apply(null, density.concat([1]));

  var thead = '<thead><tr><th class="gth">Category</th>'
    + WEEKS.map(function(w,i){
        var hot = density[i]/maxD;
        var mo = w.toLocaleDateString('en-US',{month:'short',day:'numeric'});
        return '<th style="opacity:'+(0.4+hot*0.6)+';'+(hot>0.5?'color:var(--g)':'')+'">'+mo+'</th>';
      }).join('')+'</tr></thead>';

  var tbody = '<tbody>'+CATS.map(function(cat){
    var ct = tasks.filter(function(t){ return t.cat===cat&&t.due; });
    if(!ct.length) return '';
    var dues = ct.map(function(t){ return new Date(t.due); }).sort(function(a,b){ return a-b; });
    var first=dues[0], last=dues[dues.length-1], span=last-first||1;
    var done=tasks.filter(function(t){ return t.cat===cat&&t.status==='Done'; }).length;
    var total=tasks.filter(function(t){ return t.cat===cat; }).length;
    var cells = WEEKS.map(function(w,wi){
      var we = new Date(w); we.setDate(we.getDate()+6);
      if(we<first||w>last) return '<td class="gt-wc"></td>';
      var prog=(w-first)/span;
      var ph=prog<.15?'ph1':prog>.85?'ph4':prog>.6?'ph3':'ph2';
      var l=(wi===0||we<first)?'4px':'0', r=(we>=last)?'4px':'0';
      var br=(l==='4px'?'8px':'0')+' '+(r==='4px'?'8px':'0')+' '+(r==='4px'?'8px':'0')+' '+(l==='4px'?'8px':'0');
      return '<td class="gt-wc"><div class="gt-bar '+ph+'" style="left:'+l+';right:'+r+';border-radius:'+br+'"></div></td>';
    }).join('');
    return '<tr><td class="gtc" data-filter-cat="'+esc(cat)+'">'+cat+' <span style="font-size:8px;color:var(--st);">'+Math.round(done/total*100)+'%</span></td>'+cells+'</tr>';
  }).join('')+'</tbody>';

  document.getElementById('gantt-tbl').innerHTML = thead+tbody;
  document.querySelectorAll('.gtc[data-filter-cat]').forEach(function(td){
    td.addEventListener('click', function(){
      document.getElementById('f-cat').value = td.getAttribute('data-filter-cat');
      showPage('all');
    });
  });
}

// ── ALL TASKS ────────────────────────────────────────────
function renderAll(){
  var q = (document.getElementById('f-srch').value||'').toLowerCase();
  var fc = document.getElementById('f-cat').value||'';
  var fs = document.getElementById('f-st').value||'';
  var fm = document.getElementById('f-mo').value||'';
  var filtered = tasks.filter(function(t){
    if(q&&t.name.toLowerCase().indexOf(q)<0&&t.cat.toLowerCase().indexOf(q)<0) return false;
    if(fc&&t.cat!==fc) return false;
    if(fs&&t.status!==fs) return false;
    if(fm&&t.month!==fm) return false;
    return true;
  });
  document.getElementById('tc').textContent = filtered.length;
  var el = document.getElementById('all-list');
  el.innerHTML = filtered.length
    ? filtered.map(taskHTML).join('')
    : '<div style="text-align:center;padding:36px;color:var(--st);font-size:13px;">No tasks match</div>';
  bindTaskEvents(el);
}

['f-srch','f-cat','f-st','f-mo'].forEach(function(id){
  document.getElementById(id).addEventListener('input', function(){ if(curPage==='all') renderAll(); });
  document.getElementById(id).addEventListener('change', function(){ if(curPage==='all') renderAll(); });
});

// ── TASK EVENTS (delegation) ─────────────────────────────
function bindTaskEvents(container){
  container.addEventListener('click', function(e){
    var cyc = e.target.closest('[data-cycle]');
    if(cyc){ cycleStatus(cyc.getAttribute('data-cycle')); return; }
    var ed = e.target.closest('[data-edit]');
    if(ed){ openEditModal(ed.getAttribute('data-edit')); return; }
  });
}

// ── EDIT / ADD MODALS ────────────────────────────────────
function openEditModal(id){
  var t = tasks.find(function(t){ return t.id===id; });
  if(!t) return;
  var catOpts = CATS.map(function(c){ return '<option'+(c===t.cat?' selected':'')+'>'+c+'</option>'; }).join('');
  var stOpts = ['Not started','In progress','Done','Blocked'].map(function(s){ return '<option'+(s===t.status?' selected':'')+'>'+s+'</option>'; }).join('');
  var moOpts = MONTHS.map(function(m){ return '<option'+(m===t.month?' selected':'')+'>'+m+'</option>'; }).join('');
  openModal('Edit Task',
    '<div class="mf"><label>Task</label><input id="ed-n" value="'+esc(t.name)+'"></div>'
    +'<div class="mf"><label>Status</label><select id="ed-s">'+stOpts+'</select></div>'
    +'<div class="mf"><label>Category</label><select id="ed-c">'+catOpts+'</select></div>'
    +'<div class="mf"><label>Month</label><select id="ed-m">'+moOpts+'</select></div>'
    +'<div class="mf"><label>Due Date</label><input type="date" id="ed-d" value="'+(t.due||'')+'"></div>'
    +'<div class="mf"><label>Notes</label><textarea id="ed-no">'+esc(t.notes)+'</textarea></div>'
    +'<div class="ma">'
    +'<button class="mb-btn mb-p" id="ed-save">Save</button>'
    +'<button class="mb-btn mb-d" id="ed-del">Delete</button>'
    +'<button class="mb-btn mb-s" id="ed-cancel">Cancel</button>'
    +'</div>');
  document.getElementById('ed-save').onclick = function(){
    t.name = document.getElementById('ed-n').value.trim()||t.name;
    t.status = document.getElementById('ed-s').value;
    t.cat = document.getElementById('ed-c').value;
    t.month = document.getElementById('ed-m').value;
    t.due = document.getElementById('ed-d').value;
    t.notes = document.getElementById('ed-no').value;
    saveTasks(); closeModal(); renderCurrent(); showToast('Saved ✦');
  };
  document.getElementById('ed-del').onclick = function(){
    tasks = tasks.filter(function(x){ return x.id!==id; });
    saveTasks(); closeModal(); renderCurrent(); showToast('Deleted');
  };
  document.getElementById('ed-cancel').onclick = closeModal;
}

function openAddModal(){
  var catOpts = CATS.map(function(c){ return '<option>'+c+'</option>'; }).join('');
  var moOpts = MONTHS.map(function(m){ return '<option>'+m+'</option>'; }).join('');
  openModal('Add Task',
    '<div class="mf"><label>Task Name</label><input id="ad-n" placeholder="e.g. Sculptra session #2"></div>'
    +'<div class="mf"><label>Category</label><select id="ad-c">'+catOpts+'</select></div>'
    +'<div class="mf"><label>Month</label><select id="ad-m">'+moOpts+'</select></div>'
    +'<div class="mf"><label>Due Date</label><input type="date" id="ad-d"></div>'
    +'<div class="mf"><label>Notes</label><textarea id="ad-no" placeholder="Optional…"></textarea></div>'
    +'<div class="ma">'
    +'<button class="mb-btn mb-p" id="ad-save">Add Task</button>'
    +'<button class="mb-btn mb-s" id="ad-cancel">Cancel</button>'
    +'</div>');
  setTimeout(function(){ var el=document.getElementById('ad-n'); if(el) el.focus(); }, 80);
  document.getElementById('ad-save').onclick = function(){
    var name = document.getElementById('ad-n').value.trim();
    if(!name) return;
    tasks.push({id:'t'+Date.now(),name:name,cat:document.getElementById('ad-c').value,
      month:document.getElementById('ad-m').value,due:document.getElementById('ad-d').value,
      status:'Not started',notes:document.getElementById('ad-no').value});
    saveTasks(); closeModal(); renderCurrent(); showToast('Task added ✦');
  };
  document.getElementById('ad-cancel').onclick = closeModal;
}

document.getElementById('fab-btn').addEventListener('click', openAddModal);
document.getElementById('modal').addEventListener('click', function(e){
