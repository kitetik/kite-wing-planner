function renderPhotoGrid(elId, prefix, slots, cls){
  var el = document.getElementById(elId);
  el.innerHTML = slots.map(function(slot){
    var k = prefix+'_'+slot;
    var src = photos[k];
    return '<div class="ph-slot '+cls+'" data-ph-key="'+k+'">'
      +'<input type="file" accept="image/*" style="display:none" data-ph-input="'+k+'">'
      +(src
        ? '<img src="'+src+'"><div class="ph-date">'+slot+'</div><button class="ph-rm" data-ph-rm="'+k+'">×</button>'
        : '<div class="ph-plus">＋</div><div class="ph-lbl">'+slot+'</div>')
      +'</div>';
  }).join('');
  el.querySelectorAll('.ph-slot').forEach(function(s){
    s.addEventListener('click', function(e){
      if(e.target.classList.contains('ph-rm')) return;
      s.querySelector('input[type=file]').click();
    });
  });
  el.querySelectorAll('input[type=file]').forEach(function(inp){
    inp.addEventListener('change', function(){
      if(!inp.files[0]) return;
      var k = inp.getAttribute('data-ph-input');
      var slot = k.split('_')[1];
      var r = new FileReader();
      r.onload = function(ev){
        photos[k] = ev.target.result;
        lsSet('bv3_photos', photos);
        renderTrack();
        showToast('Photo saved ✦');
      };
      r.readAsDataURL(inp.files[0]);
    });
  });
  el.querySelectorAll('.ph-rm').forEach(function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      delete photos[btn.getAttribute('data-ph-rm')];
      lsSet('bv3_photos', photos);
      renderTrack();
    });
  });
}

function renderMeasDisplay(){
  var latest = measurements[0]||null;
  var prev = measurements[1]||null;
  var fs = ['weight','waist','hips','arms'];
  var ls = ['Weight','Waist','Hips','Arms'];
  var us = ['lbs','in','in','in'];
  var base = {weight:132,waist:28.5,hips:null,arms:null};
  document.getElementById('meas-display').innerHTML = fs.map(function(f,i){
    var v = latest?latest[f]:base[f];
    var pv = prev?prev[f]:base[f];
    var chg = (v&&pv) ? parseFloat((v-pv).toFixed(1)) : null;
    var chgCls = chg!==null ? (chg<0?'pos':'neg') : '';
    return '<div class="ms-card">'
      +'<div class="ms-lbl">'+ls[i]+'</div>'
      +'<div class="ms-val">'+(v||'—')+(v?'<span class="ms-unit"> '+us[i]+'</span>':'')+'</div>'
      +(chg!==null?'<div class="ms-chg '+chgCls+'">'+(chg>0?'+':'')+chg+' from last</div>':'')
      +'</div>';
  }).join('');

  document.getElementById('meas-hist').innerHTML = measurements.length
    ? measurements.slice(0,8).map(function(m){
        return '<div class="ms-hist-row">'
          +'<span class="ms-hist-d">'+m.date+'</span>'
          +'<div class="ms-hist-vs">'
          +(m.weight?'<span class="ms-hist-v">'+m.weight+'<small style="font-size:9px;color:var(--st)">lb</small></span>':'')
          +(m.waist?'<span class="ms-hist-v">'+m.waist+'<small style="font-size:9px;color:var(--st)">w</small></span>':'')
          +(m.hips?'<span class="ms-hist-v">'+m.hips+'<small style="font-size:9px;color:var(--st)">h</small></span>':'')
          +(m.arms?'<span class="ms-hist-v">'+m.arms+'<small style="font-size:9px;color:var(--st)">a</small></span>':'')
          +'</div></div>';
      }).join('')
    : '<div style="font-size:11px;color:var(--st);padding:8px 0;">No measurements logged yet</div>';
}

document.getElementById('save-meas-btn').addEventListener('click', function(){
  var entry = {
