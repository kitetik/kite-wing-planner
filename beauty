
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Beauty">
<title>Beauty ❣️</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
<style>
:root {
  --p:#F8F4F0; --pd:#EDE6DE; --pw:#E0D6CC; --ch:#D4C4B0;
  --g:#C9A96E; --gl:#E8D5B0; --bl:#E8C4B8; --bd:#D4A090;
  --sg:#B8D4C8; --st:#8A7A70; --dk:#3A3330;
  --tx:#4A3F3A; --tl:#7A6A64; --wh:#FDFBF9;
  --sat: env(safe-area-inset-top,0px);
  --sab: env(safe-area-inset-bottom,20px);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{min-height:100%;font-family:'Jost',sans-serif;background:var(--p);color:var(--tx);font-weight:300;}
body{padding-bottom:calc(var(--sab) + 70px);}

/* HEADER */
header{background:linear-gradient(135deg,#3A3330,#5A4A44 60%,#7A6060);padding:calc(var(--sat) + 20px) 18px 18px;position:relative;}
header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--g),transparent);}
.h-row{display:flex;justify-content:space-between;align-items:center;}
.h-eye{font-size:8px;letter-spacing:3px;text-transform:uppercase;color:var(--gl);margin-bottom:4px;}
.h-name{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:300;color:var(--p);line-height:1;}
.h-name i{font-style:italic;color:var(--gl);}
.h-cd{font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;color:var(--p);text-align:right;line-height:1;}
.h-cl{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gl);}

/* BOTTOM NAV */
nav{position:fixed;bottom:0;left:0;right:0;background:var(--wh);border-top:1px solid var(--pw);display:flex;padding-bottom:var(--sab);z-index:50;box-shadow:0 -2px 16px rgba(58,51,48,.07);}
nav button{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:10px 2px 7px;background:none;border:none;cursor:pointer;font-family:'Jost',sans-serif;}
nav button .ic{font-size:16px;}
nav button .lb{font-size:7px;letter-spacing:1.5px;text-transform:uppercase;color:var(--st);}
nav button.on .lb{color:var(--dk);font-weight:400;}
nav button.on .ic{transform:scale(1.1);}

/* PAGES */
.page{display:none;padding:18px;}
.page.on{display:block;}
.pg-h{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:300;color:var(--dk);margin-bottom:2px;}
.pg-s{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--st);margin-bottom:18px;}

/* CARDS */
.card{background:var(--wh);border:1px solid var(--pw);border-radius:3px;padding:15px;margin-bottom:12px;}
.card-lbl{font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:var(--st);margin-bottom:10px;}

/* SUNDAY WIDGET */
.sun-box{background:linear-gradient(135deg,#3A3330,#5A4A44);border-radius:3px;padding:18px;margin-bottom:14px;position:relative;}
.sun-box::after{content:'✦';position:absolute;right:14px;top:12px;font-size:24px;color:rgba(201,169,110,.18);}
.sun-title{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--p);margin-bottom:3px;}
.sun-sub{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gl);margin-bottom:14px;}
.sun-scores{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;}
.ss-box{background:rgba(255,255,255,.08);border-radius:2px;padding:9px 6px;text-align:center;}
.ss-lbl{font-size:8px;letter-spacing:1px;text-transform:uppercase;color:var(--gl);margin-bottom:6px;}
.ss-dots{display:flex;justify-content:center;gap:3px;}
.ss-dot{width:14px;height:14px;border-radius:50%;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.05);cursor:pointer;transition:background .15s;}
.ss-dot.on{background:var(--g);border-color:var(--g);}
.sun-ta{width:100%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:2px;padding:9px;font-family:'Jost',sans-serif;font-size:12px;font-weight:300;color:var(--p);outline:none;min-height:56px;resize:none;margin-bottom:10px;}
.sun-ta::placeholder{color:rgba(255,255,255,.28);}
.sun-btn{width:100%;font-family:'Jost',sans-serif;font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:10px;background:var(--g);border:none;color:#fff;border-radius:2px;cursor:pointer;}
.sun-hist{margin-top:10px;}
.sh-item{background:rgba(255,255,255,.06);border-radius:2px;padding:9px;margin-top:7px;}
.sh-date{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gl);margin-bottom:5px;}
.sh-row{display:flex;flex-wrap:wrap;gap:8px;}
.sh-sc{font-size:10px;color:rgba(255,255,255,.55);}
.sh-sc span{color:var(--gl);font-family:'Cormorant Garamond',serif;font-size:14px;}
.sh-note{font-size:10px;color:rgba(255,255,255,.4);margin-top:4px;}

/* STAT GRID */
.sg{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:12px;}
.sc{background:var(--wh);border:1px solid var(--pw);border-radius:3px;padding:12px 14px;}
.sn{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:var(--dk);line-height:1;}
.sl{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--st);margin-top:2px;}
.sc.gd .sn{color:var(--g);}
.sc.ge .sn{color:#7AAA98;}
.sc.gb .sn{color:var(--bd);}

/* PROGRESS BARS */
.pr{margin-bottom:9px;}
.pm{display:flex;justify-content:space-between;font-size:10px;color:var(--tl);margin-bottom:3px;}
.pm strong{color:var(--tx);font-weight:400;}
.pb{height:3px;background:var(--pw);border-radius:2px;overflow:hidden;cursor:pointer;}
.pf{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--g),var(--bl));transition:width .7s ease;}

/* TASK ITEMS */
.ti{display:flex;align-items:flex-start;gap:9px;padding:11px 12px;background:var(--wh);border:1px solid var(--pw);border-radius:2px;margin-bottom:6px;transition:border-color .2s;}
.ti:hover{border-color:var(--ch);}
.ti.dn{opacity:.4;}
.ti.ug{border-left:2px solid var(--bd);}
.ti-l{flex:1;min-width:0;}
.ti-n{font-size:13px;color:var(--tx);font-weight:300;line-height:1.4;margin-bottom:3px;}
.ti.dn .ti-n{text-decoration:line-through;color:var(--st);}
.ti-m{display:flex;flex-wrap:wrap;gap:4px;align-items:center;}
.ti-cat{font-size:8px;letter-spacing:1px;text-transform:uppercase;padding:2px 7px;border-radius:10px;border:1px solid var(--pw);background:var(--p);color:var(--st);}
.ti-due{font-size:9px;color:var(--tl);}
.ti-due.ov{color:var(--bd);}
.ti-r{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;}
.sp{font-size:8px;letter-spacing:.5px;text-transform:uppercase;padding:3px 8px;border-radius:10px;border:none;cursor:pointer;font-family:'Jost',sans-serif;font-weight:400;white-space:nowrap;}
.sp-ns{background:var(--pw);color:var(--st);}
.sp-ip{background:var(--g);color:#fff;}
.sp-dn{background:var(--sg);color:#3A6A58;}
.sp-bl{background:var(--bl);color:var(--bd);}
.ti-ed{background:none;border:none;color:var(--ch);cursor:pointer;font-size:13px;padding:2px;}
.ti-ed:hover{color:var(--g);}

/* WEEK HEADERS */
.wh{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--g);margin:18px 0 7px;display:flex;align-items:center;gap:8px;}
.wh::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--gl),transparent);}

/* URGENT */
.urg-box{background:linear-gradient(135deg,rgba(212,160,144,.1),rgba(232,196,184,.07));border:1px solid var(--bl);border-radius:3px;padding:12px 14px;margin-bottom:12px;}
.urg-lbl{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--bd);margin-bottom:8px;}

/* PHOTOS */
.ph-sec-lbl{font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--g);margin:16px 0 8px;}
.ph-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:4px;}
.ph-grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:4px;}
.ph-slot{border:1px dashed var(--ch);border-radius:2px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;position:relative;background:var(--p);}
.ph-slot.port{aspect-ratio:3/4;}
.ph-slot.sq{aspect-ratio:1/1;}
.ph-slot:hover{border-color:var(--g);}
.ph-slot img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;}
.ph-plus{font-size:20px;color:var(--ch);position:relative;z-index:1;}
.ph-lbl{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--st);margin-top:5px;position:relative;z-index:1;}
.ph-date{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(58,51,48,.7));color:var(--p);font-size:8px;padding:12px 5px 5px;text-align:center;}
.ph-rm{position:absolute;top:3px;right:3px;background:rgba(58,51,48,.6);border:none;color:#fff;border-radius:50%;width:18px;height:18px;font-size:9px;cursor:pointer;z-index:2;display:none;align-items:center;justify-content:center;}
.ph-slot:hover .ph-rm{display:flex;}

/* MEASUREMENTS */
.ms-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:12px;}
.ms-card{background:var(--p);border:1px solid var(--pw);border-radius:2px;padding:11px;}
.ms-lbl{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--st);margin-bottom:5px;}
.ms-val{font-family:'Cormorant Garamond',serif;font-size:30px;color:var(--dk);line-height:1;}
.ms-unit{font-size:10px;color:var(--st);}
.ms-chg{font-size:9px;margin-top:2px;}
.ms-chg.pos{color:#7AAA98;}
.ms-chg.neg{color:var(--bd);}
.ms-inp-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:10px;}
.ms-field label{display:block;font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:var(--st);margin-bottom:5px;}
.ms-field input{width:100%;background:var(--p);border:1px solid var(--pw);border-radius:2px;padding:9px 10px;font-family:'Jost',sans-serif;font-size:14px;font-weight:300;color:var(--tx);outline:none;}
.ms-field input:focus{border-color:var(--g);background:var(--wh);}
.ms-hist-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--pw);font-size:10px;color:var(--tl);}
.ms-hist-d{font-size:8px;letter-spacing:1px;text-transform:uppercase;color:var(--g);}
.ms-hist-v{font-family:'Cormorant Garamond',serif;font-size:15px;color:var(--dk);}
.ms-hist-vs{display:flex;gap:10px;}

/* GANTT */
.gantt-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin:0 -18px;padding:0 18px 10px;}
.gt{border-collapse:collapse;min-width:820px;}
.gt th{font-size:8px;letter-spacing:1px;text-transform:uppercase;color:var(--st);padding:4px 3px;text-align:center;font-weight:400;border-bottom:1px solid var(--pw);white-space:nowrap;}
.gt th.gth{text-align:left;min-width:120px;padding-left:0;}
.gt td{padding:2px 1px;border-bottom:1px solid var(--pd);}
.gt td.gtc{font-size:11px;color:var(--tx);padding:5px 6px 5px 0;white-space:nowrap;cursor:pointer;font-weight:300;}
.gt td.gtc:hover{color:var(--g);}
.gt-cs{font-size:8px;color:var(--st);letter-spacing:1px;display:block;}
.gt-wc{width:28px;height:20px;position:relative;}
.gt-bar{position:absolute;top:3px;bottom:3px;border-radius:6px;opacity:.82;}
.ph1{background:var(--ch);}
.ph2{background:var(--g);}
.ph3{background:var(--bl);}
.ph4{background:var(--sg);}
.gl-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;}
.gl-item{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--tl);}
.gl-dot{width:9px;height:9px;border-radius:50%;}

/* COACH */
.coach-wrap{background:var(--wh);border:1px solid var(--pw);border-radius:3px;overflow:hidden;margin-bottom:12px;}
.co-hdr{background:linear-gradient(135deg,#3A3330,#5A4A44);padding:14px 16px;display:flex;align-items:center;gap:9px;}
.co-dot{width:7px;height:7px;border-radius:50%;background:var(--g);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.4;transform:scale(.7);}}
.co-title{font-family:'Cormorant Garamond',serif;font-size:16px;color:var(--p);font-weight:300;}
.co-sub{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gl);margin-left:auto;}
.hints{display:flex;flex-wrap:wrap;gap:6px;padding:10px 14px 4px;}
.hint-btn{font-family:'Jost',sans-serif;font-size:9px;letter-spacing:1px;text-transform:uppercase;padding:6px 11px;background:var(--p);border:1px solid var(--pw);border-radius:2px;cursor:pointer;color:var(--tl);}
.hint-btn:hover{border-color:var(--g);color:var(--dk);}
.msgs{height:300px;overflow-y:auto;padding:14px 16px;display:flex;flex-direction:column;gap:10px;scroll-behavior:smooth;}
.msgs::-webkit-scrollbar{width:3px;}
.msgs::-webkit-scrollbar-thumb{background:var(--ch);}
.msg{max-width:88%;animation:fu .25s ease;}
@keyframes fu{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}
.msg.u{align-self:flex-end;}
.msg.a{align-self:flex-start;}
.mb{padding:10px 13px;border-radius:2px;font-size:13px;line-height:1.7;font-weight:300;}
.msg.u .mb{background:var(--dk);color:var(--p);}
.msg.a .mb{background:var(--pd);color:var(--tx);border:1px solid var(--pw);}
.mt{font-size:8px;color:var(--st);margin-top:2px;}
.msg.a .mt{text-align:left;}
.msg.u .mt{text-align:right;}
.co-inp-row{border-top:1px solid var(--pw);padding:11px 14px;display:flex;gap:8px;align-items:flex-end;}
.co-ta{flex:1;min-height:38px;max-height:90px;resize:none;background:var(--p);border:1px solid var(--pw);border-radius:2px;padding:9px 10px;font-family:'Jost',sans-serif;font-size:13px;font-weight:300;color:var(--tx);outline:none;}
.co-ta:focus{border-color:var(--g);background:var(--wh);}
.co-send{font-family:'Jost',sans-serif;font-weight:300;font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:9px 14px;background:var(--dk);border:none;color:var(--p);border-radius:2px;cursor:pointer;height:38px;}
.co-send:hover{background:var(--g);}
.ty{display:flex;gap:4px;align-items:center;}
.td{width:5px;height:5px;background:var(--ch);border-radius:50%;animation:t 1.2s infinite;}
.td:nth-child(2){animation-delay:.2s;}
.td:nth-child(3){animation-delay:.4s;}
@keyframes t{0%,100%{transform:translateY(0);opacity:.4;}50%{transform:translateY(-4px);opacity:1;}}

/* FILTERS */
.frow{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;}
.fi{background:var(--wh);border:1px solid var(--pw);border-radius:2px;padding:8px 9px;font-family:'Jost',sans-serif;font-size:12px;font-weight:300;color:var(--tx);outline:none;flex:1;min-width:110px;}
.fi:focus{border-color:var(--g);}

/* MODAL */
.mo{position:fixed;inset:0;background:rgba(58,51,48,.55);z-index:200;display:none;align-items:flex-end;justify-content:center;}
.mo.on{display:flex;}
.md{background:var(--wh);border-radius:16px 16px 0 0;padding:18px 20px calc(var(--sab) + 20px);width:100%;max-height:85vh;overflow-y:auto;animation:su .25s ease;}
@keyframes su{from{transform:translateY(100%);}to{transform:translateY(0);}}
.md-handle{width:34px;height:4px;border-radius:2px;background:var(--pw);margin:0 auto 14px;}
.md-title{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:300;color:var(--dk);margin-bottom:13px;}
.mf{margin-bottom:11px;}
.mf label{display:block;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--st);margin-bottom:5px;}
.mf input,.mf select,.mf textarea{width:100%;font-family:'Jost',sans-serif;font-weight:300;font-size:13px;background:var(--p);border:1px solid var(--pw);border-radius:2px;padding:9px 10px;color:var(--tx);outline:none;}
.mf input:focus,.mf select:focus,.mf textarea:focus{border-color:var(--g);background:var(--wh);}
.mf textarea{min-height:60px;resize:vertical;}
.ma{display:flex;gap:7px;margin-top:10px;}
.mb-btn{flex:1;font-family:'Jost',sans-serif;font-weight:300;font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:11px;border:none;border-radius:2px;cursor:pointer;}
.mb-p{background:var(--dk);color:var(--p);}
.mb-p:hover{background:var(--g);}
.mb-s{background:transparent;border:1px solid var(--pw);color:var(--st);}
.mb-d{background:#C47070;color:#fff;}

/* FAB */
.fab{position:fixed;bottom:calc(var(--sab) + 76px);right:18px;width:42px;height:42px;background:var(--dk);border:none;border-radius:50%;color:var(--p);font-size:20px;cursor:pointer;box-shadow:0 4px 14px rgba(58,51,48,.28);z-index:49;display:flex;align-items:center;justify-content:center;}
.fab:hover{background:var(--g);}

/* TOAST */
.tst{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(8px);background:var(--dk);color:var(--p);padding:8px 18px;border-radius:20px;font-size:11px;letter-spacing:1px;opacity:0;transition:all .3s;pointer-events:none;z-index:300;white-space:nowrap;}
.tst.on{opacity:1;transform:translateX(-50%) translateY(0);}

.gold-line{height:1px;background:linear-gradient(90deg,transparent,var(--g),transparent);margin:16px 0;}

@media(min-width:580px){.page,.msgs{max-width:540px;margin-left:auto;margin-right:auto;}}
</style>
</head>
<body>

<header>
  <div class="h-row">
    <div>
      <div class="h-eye">Pre-Wedding Beauty</div>
      <div class="h-name">Beauty <i>❣️</i></div>
    </div>
    <div>
      <div class="h-cd" id="cdn">—</div>
      <div class="h-cl">Days to Go</div>
    </div>
  </div>
</header>

<!-- PAGES -->
<div class="page on" id="pg-dash">
  <div class="pg-h">Dashboard</div>
  <div class="pg-s" id="dashsub"></div>
  <div id="sunwrap"></div>
  <div class="sg" id="stats"></div>
  <div class="card"><div class="card-lbl">Overall</div><div id="ovprog"></div></div>
  <div class="card"><div class="card-lbl">By Category — tap to filter</div><div id="catprog"></div></div>
  <div id="urgwrap"></div>
</div>

<div class="page" id="pg-month">
  <div class="pg-h" id="month-title">This Month</div>
  <div class="pg-s">Urgents First</div>
  <div id="month-list"></div>
</div>

<div class="page" id="pg-track">
  <div class="pg-h">Progress</div>
  <div class="pg-s">Photos · Measurements · Monthly</div>
  <div class="card">
    <div class="card-lbl">Measurements — <span id="meas-month"></span></div>
    <div class="ms-grid" id="meas-display"></div>
    <div style="font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--st);margin-bottom:8px;">Log This Month</div>
    <div class="ms-inp-grid">
      <div class="ms-field"><label>Weight (lbs)</label><input type="number" id="m-w" placeholder="132" step="0.1"></div>
      <div class="ms-field"><label>Waist (in)</label><input type="number" id="m-wa" placeholder="28.5" step="0.1"></div>
      <div class="ms-field"><label>Hips (in)</label><input type="number" id="m-h" placeholder="—" step="0.1"></div>
      <div class="ms-field"><label>Arms (in)</label><input type="number" id="m-a" placeholder="—" step="0.1"></div>
    </div>
    <button class="sun-btn" id="save-meas-btn">Save Measurements ✦</button>
    <div class="gold-line"></div>
    <div id="meas-hist"></div>
  </div>
  <div class="ph-sec-lbl">Body Progress</div>
  <div class="ph-grid-3" id="ph-body"></div>
  <div class="ph-sec-lbl">Face &amp; Skin</div>
  <div class="ph-grid-2" id="ph-face"></div>
  <div class="ph-sec-lbl">Hair</div>
  <div class="ph-grid-3" id="ph-hair"></div>
  <div class="ph-sec-lbl">Nail Sets</div>
  <div class="ph-grid-3" id="ph-nails"></div>
</div>

<div class="page" id="pg-gantt">
