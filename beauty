function renderSunWidget(){
  var now = new Date();
  var mon = new Date(now); mon.setDate(now.getDate()-(now.getDay()===0?0:now.getDay()));
  var wkStr = mon.toLocaleDateString('en-US',{month:'long',day:'numeric'});
  var isSun = now.getDay()===0;

  var scoresHTML = SCORE_KEYS.map(function(k){
    var v = sunScores[k]||5;
    var dots = [1,2,3,4,5].map(function(n){
      return '<div class="ss-dot'+(n<=v?' on':'')+'" data-sk="'+k+'" data-sv="'+n+'"></div>';
    }).join('');
    return '<div class="ss-box"><div class="ss-lbl">'+k+'</div><div class="ss-dots">'+dots+'</div></div>';
  }).join('');

  var histHTML = '';
  if(sunHistory.length){
    histHTML = '<div class="sun-hist"><div style="font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--gl);margin-bottom:4px;">Past Weeks</div>'
      + sunHistory.slice(0,3).map(function(h){
        var sv = SCORE_KEYS.map(function(k){ return '<span class="sh-sc">'+k+' <span>'+(h.scores[k]||'—')+'</span></span>'; }).join('');
        return '<div class="sh-item"><div class="sh-date">'+esc(h.date)+'</div><div class="sh-row">'+sv+'</div>'+(h.notes?'<div class="sh-note">'+esc(h.notes)+'</div>':'')+'</div>';
      }).join('')+'</div>';
  }

  document.getElementById('sunwrap').innerHTML = '<div class="sun-box">'
    +'<div class="sun-title">'+(isSun?'Sunday Planning ✦':'Weekly Check-in')+'</div>'
    +'<div class="sun-sub">Week of '+wkStr+'</div>'
    +'<div class="sun-scores">'+scoresHTML+'</div>'
    +'<textarea class="sun-ta" id="sun-notes" placeholder="This week\'s wins, how you\'re feeling, what to focus on…">'+esc(lsGet('bv3_sunnotes',''))+'</textarea>'
    +'<button class="sun-btn" id="sun-save-btn">Save Week ✦</button>'
    +histHTML+'</div>';

  document.getElementById('sun-save-btn').addEventListener('click', saveSunday);
  document.querySelectorAll('.ss-dot').forEach(function(d){
    d.addEventListener('click', function(){
      var k = d.getAttribute('data-sk'), v = parseInt(d.getAttribute('data-sv'));
      sunScores[k] = v; lsSet('bv3_ss', sunScores);
      document.querySelectorAll('.ss-dot[data-sk="'+k+'"]').forEach(function(x){
        x.classList.toggle('on', parseInt(x.getAttribute('data-sv'))<=v);
      });
    });
  });
}

function saveSunday(){
  var notes = (document.getElementById('sun-notes')||{value:''}).value;
  lsSet('bv3_sunnotes', notes);
  sunHistory.unshift({date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),scores:Object.assign({},sunScores),notes:notes});
  if(sunHistory.length>20) sunHistory.pop();
  lsSet('bv3_sun', sunHistory);
  showToast('Week saved ✦');
  renderSunWidget();
}

