function isUrgent(t){
  if(t.status==='Done'||!t.due) return false;
  return (new Date(t.due)-new Date())/86400000 <= 7;
}
function isOverdue(t){
  if(t.status==='Done'||!t.due) return false;
  return new Date(t.due) < new Date();
}
function spClass(s){
  if(s==='Done') return 'sp-dn';
  if(s==='In progress') return 'sp-ip';
  if(s==='Blocked') return 'sp-bl';
  return 'sp-ns';
}
function cycleStatus(id){
  var t = tasks.find(function(t){ return t.id===id; });
  if(!t) return;
  var c = ['Not started','In progress','Done','Blocked'];
  t.status = c[(c.indexOf(t.status)+1)%c.length];
  saveTasks(); renderCurrent();
  if(t.status==='Done') showToast('✦ Done!');
}

function taskHTML(t){
  var due = t.due ? new Date(t.due).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '';
  var ov = isOverdue(t) ? ' ov' : '';
  var dn = t.status==='Done' ? ' dn' : '';
  var ug = isUrgent(t) ? ' ug' : '';
  return '<div class="ti'+dn+ug+'" data-id="'+t.id+'">'
    +'<div class="ti-l">'
    +'<div class="ti-n">'+esc(t.name)+'</div>'
    +'<div class="ti-m">'
    +'<span class="ti-cat">'+esc(t.cat)+'</span>'
    +(due?'<span class="ti-due'+ov+'">'+due+'</span>':'')
    +'</div></div>'
    +'<div class="ti-r">'
    +'<button class="sp '+spClass(t.status)+'" data-cycle="'+t.id+'">'+t.status+'</button>'
    +'<button class="ti-ed" data-edit="'+t.id+'">✎</button>'
