  });

  const projOpts = ['<option value="">All projects</option>',...PROJECTS.map(p=>`<option value="${p}" ${atFilters.project===p?'selected':''}>${p}</option>`)].join('');

  document.getElementById('panel-alltasks').innerHTML = `
    <div class="search-bar">
      <input class="search-input" placeholder="Search tasks..." value="${atFilters.search}" oninput="atFilters.search=this.value;renderAllTasks()">
      <select class="filter-sel" onchange="atFilters.month=this.value;renderAllTasks()">
        <option value="">All months</option>
        ${MONTHS_ORDER.map(m=>`<option value="${m}" ${atFilters.month===m?'selected':''}>${m}</option>`).join('')}
      </select>
      <select class="filter-sel" onchange="atFilters.owner=this.value;renderAllTasks()">
        <option value="">All owners</option>
        ${['Kite','Robbie','Both','Landscaper','Friends'].map(o=>`<option value="${o}" ${atFilters.owner===o?'selected':''}>${o}</option>`).join('')}
      </select>
      <select class="filter-sel" onchange="atFilters.status=this.value;renderAllTasks()">
        <option value="">All statuses</option>
        ${['Not Started','In Progress','Done','Blocked'].map(s=>`<option value="${s}" ${atFilters.status===s?'selected':''}>${s}</option>`).join('')}
      </select>
      <select class="filter-sel" onchange="atFilters.project=this.value;renderAllTasks()">${projOpts}</select>
      <button class="add-task-btn" onclick="openAdd()">+ Add task</button>
    </div>
    ${atFilters.search||atFilters.month||atFilters.owner||atFilters.status||atFilters.project?`<button class="mf-btn" onclick="atFilters={search:'',month:'',owner:'',status:'',project:''};renderAllTasks()">✕ Clear filters</button><br><br>`:''}
    <div class="task-count">${filtered.length} task${filtered.length!==1?'s':''}</div>
    ${filtered.map(t=>taskCard(t)).join('')}
  `;
}

