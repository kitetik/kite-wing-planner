function weekIndex(dateStr) {
  if (!dateStr) return -1;
  const d = new Date(dateStr);
  for (let i = WEEKS.length-1; i>=0; i--) {
    if (d >= new Date(WEEKS[i].start)) return i;
  }
  return 0;
}

function statusPillClass(s) {
  if (s==='Done') return 'pill-done';
  if (s==='In Progress') return 'pill-ip';
  if (s==='Blocked') return 'pill-blocked';
  return 'pill-ns';
}

function cycleStatus(id) {
  const t = tasks.find(x=>x.id===id);
  if (!t) return;
  const cycle = ['Not Started','In Progress','Done','Blocked'];
  t.status = cycle[(cycle.indexOf(t.status)+1)%cycle.length];
  saveTasks();
  renderCurrentTab();
}

function phaseClass(p) {
  const m = {Sow:'phase-sow',Grow:'phase-grow',Harvest:'phase-harvest',Use:'phase-use'};
  return m[p]||'phase-sow';
}

function isUrgent(t) {
  if (t.status==='Done') return false;
  const d = new Date(t.due);
  const now = new Date('2026-04-20');
  return d <= new Date(now.getTime() + 14*86400000);
}

function taskCard(t, showProject=true) {
  const cc = catColor(t.project);
  return `<div class="task-card ${t.status==='Done'?'done-card':''}" id="tc-${t.id}">
    <div class="task-main">
      <div class="task-name-text">${t.name}</div>
      <div class="task-badges">
        <button class="pill ${statusPillClass(t.status)}" onclick="cycleStatus('${t.id}')">${t.status}</button>
        <span class="phase-badge ${phaseClass(t.phase)}">${t.phase}</span>
        ${showProject?`<span class="cat-badge" style="background:${cc}22;color:${cc}">${t.project}</span>`:''}
        <span class="owner-txt">${t.owner}</span>
        ${t.due?`<span class="owner-txt">· ${t.due.slice(5).replace('-','/')}</span>`:''}
      </div>
      ${t.notes?`<div class="task-note-txt">${t.notes}</div>`:''}
    </div>
    <div class="task-actions">
      <button class="edit-btn" onclick="openEdit('${t.id}')">Edit</button>
    </div>
  </div>`;
}

