<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garden · September 26</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1c1a17;
  --cream: #faf6ef;
  --parchment: #f0e8d5;
  --border: #e2d9c8;
  --moss: #3a4f2f;
  --sage: #6e8f5e;
  --sage-light: #b2c9a4;
  --sage-pale: #eaf2e4;
  --gold: #b8882a;
  --gold-pale: #faf0dc;
  --blush: #c47060;
  --blush-pale: #faecea;
  --warm-gray: #8c8278;
  --alert: #b84030;
  --alert-pale: #faeae8;
  --white: #ffffff;

  --phase-sow: #5878a8;
  --phase-grow: #6e8f5e;
  --phase-harvest: #c09040;
  --phase-use: #c06070;

  --status-ns: #8c8278;
  --status-ip: #5878a8;
  --status-done: #6e8f5e;
  --status-blocked: #b84030;

  --cat-a: #6e8f5e;
  --cat-b: #5878a8;
  --cat-c: #a87838;
  --cat-d: #7858a8;
  --cat-front: #c06070;
  --cat-moon: #487888;
  --cat-pots: #a84858;
  --cat-lawn: #48a858;
  --cat-fence: #887038;
  --cat-structure: #686868;
  --cat-wedding: #c09040;
}

*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);font-weight:300;font-size:14px;height:100vh;display:flex;flex-direction:column;overflow:hidden;}

/* ── HEADER ── */
.app-header{background:var(--moss);padding:0.9rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;position:relative;overflow:hidden;}
.app-header::before{content:'';position:absolute;right:-60px;top:-60px;width:200px;height:200px;border-radius:50%;border:1px solid rgba(178,201,164,0.1);}
.app-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;color:white;position:relative;}
.app-title em{font-style:italic;color:var(--sage-light);}
.app-meta{font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.4);position:relative;}
.header-right{text-align:right;position:relative;}
.days-count{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--sage-light);line-height:1;}
.days-lbl{font-size:0.55rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.3);}

/* ── TABS ── */
.tabs{display:flex;background:var(--ink);padding:0 1rem;overflow-x:auto;flex-shrink:0;}
.tab{padding:0.7rem 1rem;font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;color:rgba(255,255,255,0.4);border-bottom:2px solid transparent;white-space:nowrap;background:none;border-top:none;border-left:none;border-right:none;font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.tab:hover{color:rgba(255,255,255,0.7);}
.tab.active{color:var(--sage-light);border-bottom-color:var(--sage);}

/* ── PANELS ── */
.panels{flex:1;overflow:hidden;position:relative;}
.panel{display:none;height:100%;overflow-y:auto;padding:1.5rem;}
.panel.active{display:block;}

/* ── SHARED ── */
.section-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400;color:var(--moss);margin-bottom:1rem;}
.card{background:white;border:1px solid var(--border);border-radius:6px;overflow:hidden;}
.pill{display:inline-flex;align-items:center;padding:0.18rem 0.55rem;border-radius:20px;font-size:0.62rem;letter-spacing:0.06em;font-weight:500;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.pill-ns{background:#f0ece6;color:var(--status-ns);}
.pill-ip{background:#e4ecf8;color:var(--status-ip);}
.pill-done{background:#e4f0e0;color:var(--status-done);}
.pill-blocked{background:#faeae8;color:var(--status-blocked);}

/* ── DASHBOARD ── */
.dash-stats{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:0.75rem;margin-bottom:1.5rem;}
.stat-card{background:white;border:1px solid var(--border);border-radius:6px;padding:0.9rem 1rem;}
.stat-n{font-family:'Cormorant Garamond',serif;font-size:2rem;line-height:1;color:var(--moss);}
.stat-l{font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);margin-top:0.2rem;}
.progress-section{margin-bottom:1.5rem;}
.progress-row{display:flex;align-items:center;gap:0.75rem;padding:0.5rem 0;border-bottom:1px solid var(--parchment);cursor:pointer;}
.progress-row:hover .prog-label{color:var(--moss);}
.prog-label{width:160px;font-size:0.75rem;flex-shrink:0;color:var(--ink);}
.prog-track{flex:1;height:5px;background:#ece7df;border-radius:3px;overflow:hidden;}
.prog-fill{height:100%;border-radius:3px;transition:width 0.4s ease;}
.prog-num{width:40px;font-size:0.68rem;color:var(--warm-gray);text-align:right;flex-shrink:0;}
.urgent-section{margin-top:1.5rem;}
.urgent-card{display:flex;align-items:flex-start;gap:0.75rem;padding:0.75rem 1rem;background:var(--alert-pale);border:1px solid #e8c0bc;border-left:3px solid var(--alert);border-radius:5px;margin-bottom:0.5rem;cursor:pointer;}
.urgent-card:hover{box-shadow:0 2px 8px rgba(184,64,48,0.1);}

/* ── MONTH VIEW ── */
.month-filters{display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:1rem;}
.mf-btn{padding:0.28rem 0.7rem;border-radius:20px;font-size:0.62rem;letter-spacing:0.07em;cursor:pointer;border:1px solid var(--border);background:white;color:var(--warm-gray);font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.mf-btn:hover{border-color:var(--sage);}
.mf-btn.active{background:var(--moss);color:white;border-color:var(--moss);}
.week-group{margin-bottom:1.5rem;}
.week-label{font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--warm-gray);margin-bottom:0.5rem;padding-bottom:0.3rem;border-bottom:1px solid var(--parchment);}
.urgent-banner{background:var(--alert-pale);border:1px solid #e8c0bc;border-left:3px solid var(--alert);border-radius:5px;padding:0.6rem 1rem;margin-bottom:1rem;font-size:0.75rem;}
.urgent-banner strong{color:var(--alert);}

/* ── TASK CARD ── */
.task-card{display:flex;align-items:flex-start;gap:0.75rem;padding:0.65rem 0.9rem;background:white;border:1px solid var(--border);border-radius:5px;margin-bottom:0.4rem;transition:box-shadow 0.15s;}
.task-card:hover{box-shadow:0 2px 8px rgba(30,26,23,0.07);}
.task-card.done-card{opacity:0.55;}
.task-main{flex:1;min-width:0;}
.task-name-text{font-size:0.8rem;line-height:1.4;font-weight:400;}
.task-card.done-card .task-name-text{text-decoration:line-through;}
.task-badges{display:flex;gap:0.35rem;margin-top:0.25rem;flex-wrap:wrap;align-items:center;}
.cat-badge{display:inline-block;padding:0.1rem 0.4rem;border-radius:3px;font-size:0.58rem;letter-spacing:0.06em;font-weight:500;}
.phase-badge{display:inline-block;padding:0.1rem 0.4rem;border-radius:3px;font-size:0.58rem;letter-spacing:0.06em;font-weight:500;}
.phase-sow{background:#e4ecf8;color:var(--phase-sow);}
.phase-grow{background:#e4f0e0;color:var(--phase-grow);}
.phase-harvest{background:#faf0dc;color:var(--phase-harvest);}
.phase-use{background:#faecea;color:var(--phase-use);}
.owner-txt{font-size:0.62rem;color:var(--warm-gray);}
.task-note-txt{font-size:0.7rem;color:var(--warm-gray);font-style:italic;margin-top:0.2rem;line-height:1.4;}
.task-actions{display:flex;gap:0.3rem;align-items:flex-start;flex-shrink:0;}
.edit-btn{padding:0.2rem 0.5rem;border-radius:3px;font-size:0.6rem;cursor:pointer;border:1px solid var(--border);background:white;color:var(--warm-gray);font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.edit-btn:hover{border-color:var(--sage);color:var(--moss);}

/* ── GANTT ── */
.gantt-wrap{overflow-x:auto;}
.gantt-table{border-collapse:collapse;min-width:1200px;width:100%;}
.gantt-table th{font-size:0.55rem;letter-spacing:0.08em;text-transform:uppercase;padding:0.4rem 0.3rem;background:var(--parchment);border-bottom:1px solid var(--border);color:var(--warm-gray);white-space:nowrap;font-weight:500;}
.gantt-table th.project-th{text-align:left;min-width:160px;padding-left:0.75rem;}
.gantt-table th.week-th{text-align:center;width:44px;border-left:1px solid var(--border);}
.gantt-table td{padding:0.3rem 0.3rem;border-bottom:1px solid #f5f0e8;vertical-align:middle;}
.gantt-table tr:hover td{background:#fdfaf5;cursor:pointer;}
.project-cell{min-width:160px;padding-left:0.75rem;}
.project-name-g{font-size:0.75rem;font-weight:400;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:155px;}
.project-cat-g{font-size:0.58rem;color:var(--warm-gray);}
.week-td{width:44px;text-align:center;border-left:1px solid #f5f0e8;padding:0.2rem;}
.g-bar{height:12px;border-radius:3px;width:90%;margin:0 auto;}
.g-bar-sow{background:var(--phase-sow);}
.g-bar-grow{background:var(--phase-grow);}
.g-bar-harvest{background:var(--phase-harvest);}
.g-bar-use{background:var(--phase-use);}
.g-bar-done{background:var(--sage-light);}
.heat-0{background:white;}
.heat-1{background:#f5f8f2;}
.heat-2{background:#e8f2e0;}
.heat-3{background:#d4e8c4;}
.heat-4{background:#b8d8a0;}
.gantt-panel-overlay{position:fixed;inset:0;background:rgba(30,26,23,0.5);z-index:500;display:none;align-items:flex-end;}
.gantt-panel-overlay.open{display:flex;}
.gantt-side-panel{background:white;width:380px;max-width:95vw;height:100vh;overflow-y:auto;padding:1.5rem;box-shadow:-4px 0 20px rgba(30,26,23,0.15);margin-left:auto;}
.gp-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400;color:var(--moss);margin-bottom:0.25rem;}
.gp-close{float:right;background:none;border:none;font-size:1.2rem;cursor:pointer;color:var(--warm-gray);margin-top:-0.2rem;}

/* ── ALL TASKS ── */
.search-bar{display:flex;gap:0.5rem;margin-bottom:1rem;flex-wrap:wrap;}
.search-input{flex:1;min-width:160px;padding:0.5rem 0.75rem;border:1px solid var(--border);border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.8rem;background:white;outline:none;}
.search-input:focus{border-color:var(--sage);}
.filter-sel{padding:0.5rem 0.6rem;border:1px solid var(--border);border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.75rem;background:white;color:var(--ink);outline:none;cursor:pointer;}
.task-count{font-size:0.7rem;color:var(--warm-gray);margin-bottom:0.75rem;}
.add-task-btn{padding:0.5rem 1rem;background:var(--moss);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.75rem;cursor:pointer;transition:background 0.15s;white-space:nowrap;}
.add-task-btn:hover{background:#2a3f22;}

/* ── ASSISTANT ── */
.assistant-wrap{display:flex;flex-direction:column;height:100%;gap:0;}
.chat-history{flex:1;overflow-y:auto;padding-bottom:1rem;}
.chat-msg{margin-bottom:1rem;max-width:85%;}
.chat-msg.user{margin-left:auto;}
.chat-bubble{padding:0.75rem 1rem;border-radius:10px;font-size:0.8rem;line-height:1.6;}
.chat-msg.assistant .chat-bubble{background:white;border:1px solid var(--border);}
.chat-msg.user .chat-bubble{background:var(--moss);color:white;}
.chat-msg .chat-meta{font-size:0.6rem;color:var(--warm-gray);margin-top:0.2rem;}
.chat-msg.user .chat-meta{text-align:right;}
.hint-row{display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:0.75rem;}
.hint-btn{padding:0.3rem 0.7rem;border-radius:20px;border:1px solid var(--border);background:white;font-size:0.68rem;color:var(--warm-gray);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.15s;}
.hint-btn:hover{border-color:var(--sage);color:var(--moss);}
.chat-input-row{display:flex;gap:0.5rem;padding-top:0.75rem;border-top:1px solid var(--border);}
.chat-input{flex:1;padding:0.6rem 0.9rem;border:1px solid var(--border);border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.8rem;outline:none;resize:none;}
.chat-input:focus{border-color:var(--sage);}
.chat-send{padding:0.6rem 1rem;background:var(--moss);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.75rem;cursor:pointer;}
.thinking{color:var(--warm-gray);font-style:italic;font-size:0.75rem;}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(30,26,23,0.5);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem;}
.modal-overlay.open{display:flex;}
.modal{background:white;border-radius:8px;width:480px;max-width:100%;max-height:90vh;overflow-y:auto;padding:1.5rem;}
.modal-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--moss);margin-bottom:1.25rem;}
.form-row{margin-bottom:0.9rem;}
.form-label{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);margin-bottom:0.3rem;display:block;}
.form-input,.form-select,.form-textarea{width:100%;padding:0.5rem 0.7rem;border:1px solid var(--border);border-radius:4px;font-family:'DM Sans',sans-serif;font-size:0.8rem;background:white;color:var(--ink);outline:none;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--sage);}
.form-textarea{resize:vertical;min-height:70px;}
.modal-actions{display:flex;gap:0.5rem;margin-top:1.25rem;flex-wrap:wrap;}
.btn-primary{padding:0.55rem 1.2rem;background:var(--moss);color:white;border:none;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.78rem;cursor:pointer;}
.btn-secondary{padding:0.55rem 1rem;background:white;color:var(--ink);border:1px solid var(--border);border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.78rem;cursor:pointer;}
.btn-danger{padding:0.55rem 1rem;background:var(--alert-pale);color:var(--alert);border:1px solid #e8c0bc;border-radius:5px;font-family:'DM Sans',sans-serif;font-size:0.78rem;cursor:pointer;margin-left:auto;}
.gantt-impact{background:var(--sage-pale);border-radius:4px;padding:0.6rem 0.8rem;font-size:0.72rem;color:var(--moss);margin-top:0.5rem;line-height:1.5;}

/* ── ROBBIE ── */
.robbie-header{background:linear-gradient(135deg,#2a3f55,#1a2f45);border-radius:6px;padding:1.2rem 1.5rem;margin-bottom:1.5rem;color:white;}
.robbie-header h2{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;}
.robbie-header p{font-size:0.72rem;opacity:0.6;margin-top:0.25rem;}

/* mobile */
@media(max-width:600px){
  .app-header{padding:0.75rem 1rem;}
  .panel{padding:1rem;}
  .dash-stats{grid-template-columns:repeat(3,1fr);}
}
</style>
</head>
<body>

<div class="app-header">
  <div>
    <div class="app-title">Garden · <em>September 26</em></div>
    <div class="app-meta">Catskill NY · 34 varieties · 9 zones</div>
  </div>
  <div class="header-right">
    <div class="days-count" id="daysNum">—</div>
    <div class="days-lbl">days to go</div>
  </div>
</div>

<div class="tabs">
  <button class="tab active" onclick="showTab('dashboard',this)">Dashboard</button>
  <button class="tab" onclick="showTab('month',this)">This Month</button>
  <button class="tab" onclick="showTab('gantt',this)">◈ Gantt</button>
  <button class="tab" onclick="showTab('assistant',this)">✦ Assistant</button>
  <button class="tab" onclick="showTab('alltasks',this)">All Tasks</button>
  <button class="tab" onclick="showTab('robbie',this)">Robbie</button>
</div>

<div class="panels">
  <div class="panel active" id="panel-dashboard"></div>
  <div class="panel" id="panel-month"></div>
  <div class="panel" id="panel-gantt"></div>
  <div class="panel" id="panel-assistant"></div>
  <div class="panel" id="panel-alltasks"></div>
  <div class="panel" id="panel-robbie"></div>
</div>

<!-- Gantt side panel -->
<div class="gantt-panel-overlay" id="ganttOverlay" onclick="closeGanttPanel(event)">
  <div class="gantt-side-panel" id="ganttSidePanel">
    <button class="gp-close" onclick="closeGanttPanelDirect()">✕</button>
    <div class="gp-title" id="gpTitle">—</div>
    <div id="gpBody"></div>
  </div>
</div>

<!-- Edit/Add Modal -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-title" id="modalTitle">Edit Task</div>
    <div class="form-row">
      <label class="form-label">Task Name</label>
      <input class="form-input" id="fName" placeholder="Task name">
    </div>
    <div class="form-row">
      <label class="form-label">Status</label>
      <select class="form-select" id="fStatus">
        <option value="Not Started">Not Started</option>
        <option value="In Progress">In Progress</option>
        <option value="Done">Done</option>
        <option value="Blocked">Blocked</option>
      </select>
    </div>
    <div class="form-row">
      <label class="form-label">Owner</label>
      <select class="form-select" id="fOwner">
        <option value="Kite">Kite</option>
        <option value="Robbie">Robbie</option>
        <option value="Both">Both</option>
        <option value="Landscaper">Landscaper</option>
        <option value="Friends">Friends</option>
      </select>
    </div>
    <div class="form-row">
      <label class="form-label">Project / Zone</label>
      <select class="form-select" id="fProject"></select>
    </div>
    <div class="form-row">
      <label class="form-label">Phase</label>
      <select class="form-select" id="fPhase">
        <option value="Sow">Sow</option>
        <option value="Grow">Grow</option>
        <option value="Harvest">Harvest</option>
        <option value="Use">Use</option>
      </select>
    </div>
    <div class="form-row">
      <label class="form-label">Due Date</label>
      <input class="form-input" id="fDue" type="date">
    </div>
    <div class="form-row">
      <label class="form-label">Month</label>
      <select class="form-select" id="fMonth">
        <option>April</option><option>May</option><option>June</option>
        <option>July</option><option>August</option><option>September</option>
      </select>
    </div>
    <div class="form-row">
      <label class="form-label">Notes</label>
      <textarea class="form-textarea" id="fNotes" placeholder="Additional notes..."></textarea>
    </div>
    <div class="gantt-impact" id="ganttImpact" style="display:none"></div>
    <div class="modal-actions">
      <button class="btn-primary" onclick="saveTask()">Save</button>
      <button class="btn-secondary" onclick="closeModal()">Cancel</button>
      <button class="btn-danger" id="deleteBtn" onclick="deleteTask()" style="display:none">Delete</button>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════
// DATA
// ══════════════════════════════════════════

const PROJECTS = [
  // Cutting beds
  "Bed A — Dahlias","Bed A — Sunflower","Bed A — Roses",
  "Bed B — Zinnias","Bed C — Cosmos","Bed C — Nicotiana",
  "Bed C — Amaranth","Bed D — Scabiosa","Bed D — Feverfew",
  "Bed D — Celosia","Bed D — Grasses",
  // Other garden zones
  "Front Yard — Roses + Trellises","Front Yard — Cottage Bed",
  "Front Yard — Window Boxes","Front Yard — Maple Ring",
  "Front Yard — Steps + Pots","Front Yard — Lawn",
  "Back Fence — Clematis","Back Fence — Planting",
  "Moon Garden — Structure","Moon Garden — Planting","Moon Garden — Lighting",
  "Arch — Tall Pots","Arch — Short Pots","Arch — Floating Bowl",
  "Deck + Doorstep Pots",
  // Infrastructure
  "Irrigation System","Bulk Materials","Seedling Care",
  // Wedding florals
  "Bridal Bouquet","Bridesmaids + Boutonnieres",
  "Table Centerpieces","Welcome Arrangement","Rehearsal Dinner Florals",
  // General
  "Lawn","Friend Weekends","September Harvest"
];

const CAT_COLORS = {
  "Bed A": "var(--cat-a)", "Bed B": "var(--cat-b)",
  "Bed C": "var(--cat-c)", "Bed D": "var(--cat-d)",
  "Front Yard": "var(--cat-front)", "Moon Garden": "var(--cat-moon)",
  "Arch": "var(--cat-pots)", "Deck": "var(--cat-pots)",
  "Back Fence": "var(--cat-fence)", "Lawn": "var(--cat-lawn)",
  "Irrigation": "var(--cat-structure)", "Bulk": "var(--cat-structure)",
  "Seedling": "var(--cat-structure)", "Bridal": "var(--cat-wedding)",
  "Bridesmaids": "var(--cat-wedding)", "Table": "var(--cat-wedding)",
  "Welcome": "var(--cat-wedding)", "Rehearsal": "var(--cat-wedding)",
  "Friend": "var(--cat-pots)", "September": "var(--cat-wedding)",
};

function catColor(project) {
  for (const [k,v] of Object.entries(CAT_COLORS)) {
    if (project.startsWith(k)) return v;
  }
