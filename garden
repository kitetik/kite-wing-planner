// ── LOCAL STORAGE ──
const STORAGE_KEY = 'garden_app_tasks_v2';

function loadTasks() {
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const parsed = JSON.parse(saved);
      // Merge: keep saved statuses, add any new seed tasks
      const savedMap = new Map(parsed.map(t => [t.id, t]));
      return SEED_TASKS.map(t => savedMap.has(t.id) ? {...t, ...savedMap.get(t.id), name:t.name} : t);
    }
  } catch(e) {}
  return [...SEED_TASKS];
}

function saveTasks() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(tasks)); } catch(e) {}
}

