// ASSISTANT
// ══════════════════════════════════════════
function renderAssistant() {
  if (document.getElementById('chatHistory')) return; // already rendered
  document.getElementById('panel-assistant').innerHTML = `
    <div class="assistant-wrap">
      <div class="chat-history" id="chatHistory">
        <div class="chat-msg assistant">
          <div class="chat-bubble">Hi! I'm your garden assistant. I know all ${tasks.length} tasks across your ${PROJECTS.length} projects. I can help you update task status, add new tasks, answer questions about your plan, or think through next steps. What do you need?</div>
        </div>
      </div>
      <div class="hint-row" id="hintRow">
        <button class="hint-btn" onclick="sendHint('What are the most urgent tasks right now?')">Urgent tasks?</button>
        <button class="hint-btn" onclick="sendHint('What does Robbie need to do this week?')">Robbie this week</button>
        <button class="hint-btn" onclick="sendHint('How are the dahlias looking?')">Dahlia status</button>
        <button class="hint-btn" onclick="sendHint('What\\'s the biggest gap in my plan?')">Biggest gap</button>
        <button class="hint-btn" onclick="sendHint('What should I focus on in May?')">May priorities</button>
      </div>
      <div class="chat-input-row">
        <textarea class="chat-input" id="chatInput" rows="2" placeholder="Ask about your garden plan..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendChat();}"></textarea>
        <button class="chat-send" onclick="sendChat()">Send</button>
      </div>
    </div>
  `;
}

function sendHint(msg) {
  document.getElementById('chatInput').value = msg;
  sendChat();
}

async function sendChat() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';

  appendMsg('user', msg);
  appendMsg('assistant', '<span class="thinking">Thinking...</span>', 'thinking-msg');

  chatHistory.push({role:'user', content: msg});

  // Build context
  const urgentList = tasks.filter(t=>isUrgent(t)&&t.status!=='Done').map(t=>`- ${t.name} (${t.project}, due ${t.due}, ${t.owner})`).join('\n');
  const statusSummary = `Total: ${tasks.length}, Done: ${tasks.filter(t=>t.status==='Done').length}, In Progress: ${tasks.filter(t=>t.status==='In Progress').length}, Blocked: ${tasks.filter(t=>t.status==='Blocked').length}`;
  const projectList = PROJECTS.join(', ');

  const systemPrompt = `You are a knowledgeable garden assistant for a wedding garden in Catskill, NY. The wedding is September 26, 2026. You have access to the full garden task database.

TASK STATUS SUMMARY: ${statusSummary}
PROJECTS: ${projectList}
URGENT TASKS (due within 2 weeks):
${urgentList || 'None currently'}

KEY GARDEN FACTS:
- 4 cutting beds (A: dahlias/sunflower/roses, B: zinnias, C: cosmos/nicotiana/amaranth, D: scabiosa/feverfew/celosia/grasses)
- Critical gaps: scabiosa (-65 stems), sunflower (-15), grasses (-35 each)
- Strong surpluses: nicotiana (+224), zinnias (+96-180), cosmos (+70-94)
- Seeds just sprouting now (started late) — succession waves critical
- Staffing: Kite solo now, Kite+Robbie+landscaper all May, half-time June, slammed July, fully present August
- Three friend weekends: May 2-4 (labor), May 16-18 (big transplant), Sept 19-21 (harvest party)
- Irrigation system still needs to be ordered — urgent gap
- Moon garden bench + trellis needs to be built in May
- Climbing roses reserved but first-year only — eucalyptus garland as backup

Be concise, practical, and specific. Reference actual task names and project names when relevant. If asked to add or update tasks, describe what you would do and ask for confirmation.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: chatHistory.slice(-10),
      })
    });
    const data = await response.json();
    const reply = data.content?.[0]?.text || 'Sorry, I had trouble with that.';
    chatHistory.push({role:'assistant', content: reply});
    document.getElementById('thinking-msg')?.remove();
    appendMsg('assistant', reply);
  } catch(e) {
    document.getElementById('thinking-msg')?.remove();
    appendMsg('assistant', 'Connection issue — please try again.');
  }
}

function appendMsg(role, content, id='') {
  const div = document.createElement('div');
  div.className = `chat-msg ${role}`;
  if (id) div.id = id;
  div.innerHTML = `<div class="chat-bubble">${content}</div>`;
  document.getElementById('chatHistory').appendChild(div);
  document.getElementById('chatHistory').scrollTop = 999999;
}

