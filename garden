let monthFilter = 'April';

function renderMonth() {
  const monthTasks = tasks.filter(t=>t.month===monthFilter);
  const urgents = monthTasks.filter(t=>isUrgent(t)&&t.status!=='Done');

  const monthBtns = MONTHS_ORDER.map(m=>`<button class="mf-btn ${m===monthFilter?'active':''}" onclick="setMonthFilter('${m}',this)">${m}</button>`).join('');

  // Group by week
  const weekGroups = {};
  monthTasks.forEach(t=>{
    const wi = weekIndex(t.due);
    const wl = wi>=0 ? WEEKS[wi].label : 'No date';
    if (!weekGroups[wl]) weekGroups[wl] = [];
    weekGroups[wl].push(t);
  });

  const urgentBanner = urgents.length ? `<div class="urgent-banner">🔴 <strong>${urgents.length} urgent task${urgents.length>1?'s':''} need attention this week</strong></div>` : '';
  const urgentCards = urgents.map(t=>taskCard(t)).join('');

  const weekHTML = Object.entries(weekGroups).map(([wl,wt])=>`
    <div class="week-group">
      <div class="week-label">Week of ${wl}</div>
      ${wt.map(t=>taskCard(t)).join('')}
    </div>`).join('');

  document.getElementById('panel-month').innerHTML = `
    <div class="month-filters">${monthBtns}</div>
    ${urgentBanner}
    ${urgents.length ? `<div class="week-group"><div class="week-label" style="color:var(--alert)">Urgent this period</div>${urgentCards}</div>` : ''}
    ${weekHTML}
  `;
}

function setMonthFilter(m, btn) {
  monthFilter = m;
  renderMonth();
}

// ══════════════════════════════════════════
// GANTT
// ══════════════════════════════════════════
function renderGantt() {
  // Heat map: tasks per week
  const heatMap = WEEKS.map((_,i)=>{
    const c = tasks.filter(t=>weekIndex(t.due)===i&&t.status!=='Done').length;
    return c;
  });
  const maxHeat = Math.max(...heatMap, 1);

  const weekHeaders = WEEKS.map((w,i)=>{
    const heat = Math.min(4, Math.ceil(heatMap[i]/maxHeat*4));
    return `<th class="week-th heat-${heat}" title="${heatMap[i]} tasks">${w.label}</th>`;
  }).join('');

  const rows = PROJECTS.map(p=>{
    const pt = tasks.filter(t=>t.project===p);
    if (!pt.length) return '';
    const done = pt.filter(t=>t.status==='Done').length;
    const cc = catColor(p);

    // Phase ranges from task due dates
    const sowTasks = pt.filter(t=>t.phase==='Sow');
    const growTasks = pt.filter(t=>t.phase==='Grow');
    const harvestTasks = pt.filter(t=>t.phase==='Harvest');
    const useTasks = pt.filter(t=>t.phase==='Use');

    const phaseDates = {
      Sow: sowTasks.map(t=>t.due).filter(Boolean),
      Grow: growTasks.map(t=>t.due).filter(Boolean),
      Harvest: harvestTasks.map(t=>t.due).filter(Boolean),
      Use: useTasks.map(t=>t.due).filter(Boolean),
    };

    // Get week range for each phase
    function phaseRange(dates) {
      if (!dates.length) return null;
      const idxs = dates.map(d=>weekIndex(d)).filter(i=>i>=0);
      if (!idxs.length) return null;
      return [Math.min(...idxs), Math.max(...idxs)];
    }

    const ranges = {
      Sow: phaseRange(phaseDates.Sow),
      Grow: phaseRange(phaseDates.Grow),
      Harvest: phaseRange(phaseDates.Harvest),
      Use: phaseRange(phaseDates.Use),
    };

    const cells = WEEKS.map((_,wi)=>{
      let barClass = '';
      for (const [phase, range] of Object.entries(ranges)) {
        if (range && wi>=range[0] && wi<=range[1]) {
          barClass = `g-bar-${phase.toLowerCase()}`;
          break;
        }
      }
      const bar = barClass ? `<div class="g-bar ${barClass}"></div>` : '';
      return `<td class="week-td">${bar}</td>`;
    }).join('');

    const pct = Math.round(done/pt.length*100);
    return `<tr onclick="openGanttPanel('${p.replace(/'/g,"\\'")}')">
      <td class="project-cell">
        <div class="project-name-g">${p}</div>
        <div class="project-cat-g">${done}/${pt.length} · ${pct}%</div>
      </td>
      ${cells}
    </tr>`;
  }).filter(Boolean).join('');

  document.getElementById('panel-gantt').innerHTML = `
    <div style="margin-bottom:0.75rem;font-size:0.72rem;color:var(--warm-gray)">Click any project row to view its tasks. Colors: <span style="color:var(--phase-sow)">■ Sow</span> · <span style="color:var(--phase-grow)">■ Grow</span> · <span style="color:var(--phase-harvest)">■ Harvest</span> · <span style="color:var(--phase-use)">■ Use</span>. Week headers heat-colored by task density.</div>
    <div class="gantt-wrap">
      <table class="gantt-table">
        <thead><tr>
          <th class="project-th">Project</th>
          ${weekHeaders}
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
  `;
}

function openGanttPanel(project) {
  const pt = tasks.filter(t=>t.project===project);
  document.getElementById('gpTitle').textContent = project;
  document.getElementById('gpBody').innerHTML = `
    <div style="font-size:0.68rem;color:var(--warm-gray);margin-bottom:1rem">${pt.length} tasks · ${pt.filter(t=>t.status==='Done').length} done</div>
    ${pt.map(t=>taskCard(t,false)).join('')}
    <button class="add-task-btn" style="margin-top:1rem;width:100%" onclick="openAdd('${project.replace(/'/g,"\\'")}')">+ Add task to this project</button>
  `;
  document.getElementById('ganttOverlay').classList.add('open');
}

function closeGanttPanel(e) {
  if (e.target===document.getElementById('ganttOverlay')) closeGanttPanelDirect();
}
function closeGanttPanelDirect() {
  document.getElementById('ganttOverlay').classList.remove('open');
}

