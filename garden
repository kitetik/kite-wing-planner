function renderDashboard() {
  const total = tasks.length;
  const done = tasks.filter(t=>t.status==='Done').length;
  const ip = tasks.filter(t=>t.status==='In Progress').length;
  const blocked = tasks.filter(t=>t.status==='Blocked').length;
  const urgent = tasks.filter(t=>isUrgent(t)&&t.status!=='Done').length;
  const pct = Math.round(done/total*100);

  // Month progress
  const monthBars = MONTHS_ORDER.map(m=>{
    const mt = tasks.filter(t=>t.month===m);
    const md = mt.filter(t=>t.status==='Done').length;
    const mp = mt.length ? Math.round(md/mt.length*100) : 0;
    return `<div class="progress-row" onclick="filterByMonth('${m}')">
      <div class="prog-label">${m}</div>
      <div class="prog-track"><div class="prog-fill" style="width:${mp}%;background:var(--sage)"></div></div>
      <div class="prog-num">${md}/${mt.length}</div>
    </div>`;
  }).join('');

  // Project progress
  const projBars = PROJECTS.map(p=>{
    const pt = tasks.filter(t=>t.project===p);
    if (!pt.length) return '';
    const pd = pt.filter(t=>t.status==='Done').length;
    const pp = Math.round(pd/pt.length*100);
    const cc = catColor(p);
    return `<div class="progress-row" onclick="filterByProject('${p}')">
      <div class="prog-label" style="font-size:0.7rem">${p}</div>
      <div class="prog-track"><div class="prog-fill" style="width:${pp}%;background:${cc}"></div></div>
      <div class="prog-num">${pd}/${pt.length}</div>
    </div>`;
  }).filter(Boolean).join('');

  const urgentCards = tasks.filter(t=>isUrgent(t)&&t.status!=='Done').slice(0,8).map(t=>`
    <div class="urgent-card" onclick="openEdit('${t.id}')">
      <div style="flex:1">
        <div style="font-size:0.78rem;font-weight:400">${t.name}</div>
        <div style="font-size:0.65rem;color:var(--warm-gray);margin-top:0.15rem">${t.project} · Due ${t.due||'TBD'} · ${t.owner}</div>
      </div>
      <button class="pill ${statusPillClass(t.status)}" onclick="event.stopPropagation();cycleStatus('${t.id}')">${t.status}</button>
    </div>`).join('');

  document.getElementById('panel-dashboard').innerHTML = `
    <div class="dash-stats">
      <div class="stat-card"><div class="stat-n">${total}</div><div class="stat-l">Total tasks</div></div>
      <div class="stat-card"><div class="stat-n" style="color:var(--status-done)">${done}</div><div class="stat-l">Done</div></div>
      <div class="stat-card"><div class="stat-n" style="color:var(--status-ip)">${ip}</div><div class="stat-l">In progress</div></div>
      <div class="stat-card"><div class="stat-n" style="color:var(--status-blocked)">${blocked}</div><div class="stat-l">Blocked</div></div>
      <div class="stat-card"><div class="stat-n" style="color:var(--alert)">${urgent}</div><div class="stat-l">Urgent</div></div>
      <div class="stat-card"><div class="stat-n">${pct}%</div><div class="stat-l">Complete</div></div>
    </div>
    <div style="background:white;border:1px solid var(--border);border-radius:6px;padding:0.75rem 1rem;margin-bottom:1.5rem;">
      <div style="display:flex;justify-content:space-between;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--warm-gray);margin-bottom:0.4rem;">
        <span>Overall progress</span><span>${pct}%</span>
      </div>
      <div style="height:8px;background:#ece7df;border-radius:4px;overflow:hidden;">
        <div style="height:100%;width:${pct}%;background:linear-gradient(to right,var(--sage),var(--gold));border-radius:4px;transition:width 0.6s ease;"></div>
      </div>
    </div>
    <div class="progress-section">
      <div class="section-title">By Month <span style="font-size:0.7rem;color:var(--warm-gray);font-family:'DM Sans',sans-serif;font-weight:300"> — click to filter</span></div>
      ${monthBars}
    </div>
    <div class="progress-section">
      <div class="section-title">By Project <span style="font-size:0.7rem;color:var(--warm-gray);font-family:'DM Sans',sans-serif;font-weight:300"> — click to filter</span></div>
      ${projBars}
    </div>
    ${urgentCards ? `<div class="urgent-section"><div class="section-title" style="color:var(--alert)">🔴 Urgent — due within 2 weeks</div>${urgentCards}</div>` : ''}
  `;
}

function filterByMonth(m) {
  atFilters.month = m;
  showTab('alltasks', document.querySelectorAll('.tab')[4]);
}
function filterByProject(p) {
  atFilters.project = p;
  showTab('alltasks', document.querySelectorAll('.tab')[4]);
}

