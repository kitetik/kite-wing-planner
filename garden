// MODAL — EDIT + ADD
// ══════════════════════════════════════════
function populateProjectSelect(selected='') {
  document.getElementById('fProject').innerHTML = PROJECTS.map(p=>`<option value="${p}" ${p===selected?'selected':''}>${p}</option>`).join('');
}

function openEdit(id) {
  const t = tasks.find(x=>x.id===id);
  if (!t) return;
  editingId = id;
  document.getElementById('modalTitle').textContent = 'Edit Task';
  document.getElementById('fName').value = t.name;
  document.getElementById('fStatus').value = t.status;
  document.getElementById('fOwner').value = t.owner;
  populateProjectSelect(t.project);
  document.getElementById('fPhase').value = t.phase||'Sow';
  document.getElementById('fDue').value = t.due||'';
  document.getElementById('fMonth').value = t.month||'April';
  document.getElementById('fNotes').value = t.notes||'';
  document.getElementById('deleteBtn').style.display = 'inline-block';
  updateGanttImpact(t.project);
  document.getElementById('modalOverlay').classList.add('open');
}

function openAdd(project='') {
  editingId = null;
  document.getElementById('modalTitle').textContent = 'Add Task';
  document.getElementById('fName').value = '';
  document.getElementById('fStatus').value = 'Not Started';
  document.getElementById('fOwner').value = 'Kite';
  populateProjectSelect(project);
  document.getElementById('fPhase').value = 'Sow';
  document.getElementById('fDue').value = '';
  document.getElementById('fMonth').value = 'April';
  document.getElementById('fNotes').value = '';
  document.getElementById('deleteBtn').style.display = 'none';
  document.getElementById('ganttImpact').style.display = 'none';
  document.getElementById('modalOverlay').classList.add('open');
}

function updateGanttImpact(project) {
  const pt = tasks.filter(t=>t.project===project);
  if (!pt.length) { document.getElementById('ganttImpact').style.display='none'; return; }
  const sowDates = pt.filter(t=>t.phase==='Sow'&&t.due).map(t=>t.due).sort();
  const harvestDates = pt.filter(t=>t.phase==='Harvest'&&t.due).map(t=>t.due).sort();
  const el = document.getElementById('ganttImpact');
  el.style.display = 'block';
  el.innerHTML = `<strong>Gantt impact for ${project}:</strong><br>
    ${sowDates.length ? `Sow phase: ${sowDates[0]} → ${sowDates[sowDates.length-1]}` : 'No sow tasks'}<br>
    ${harvestDates.length ? `Harvest: ${harvestDates[0]}` : 'No harvest tasks set'}`;
}

function saveTask() {
  const name = document.getElementById('fName').value.trim();
  if (!name) return;
  if (editingId) {
    const t = tasks.find(x=>x.id===editingId);
    if (t) {
      t.name = name;
      t.status = document.getElementById('fStatus').value;
      t.owner = document.getElementById('fOwner').value;
      t.project = document.getElementById('fProject').value;
      t.phase = document.getElementById('fPhase').value;
      t.due = document.getElementById('fDue').value;
      t.month = document.getElementById('fMonth').value;
      t.notes = document.getElementById('fNotes').value;
    }
  } else {
    tasks.push({
      id: 'u'+Date.now(),
      project: document.getElementById('fProject').value,
      category: 'Custom',
      name, owner: document.getElementById('fOwner').value,
      due: document.getElementById('fDue').value,
      month: document.getElementById('fMonth').value,
      status: document.getElementById('fStatus').value,
      phase: document.getElementById('fPhase').value,
      notes: document.getElementById('fNotes').value,
    });
  }
  saveTasks();
  closeModal();
  renderCurrentTab();
  // Refresh gantt panel if open
  if (document.getElementById('ganttOverlay').classList.contains('open')) {
    const title = document.getElementById('gpTitle').textContent;
    openGanttPanel(title);
  }
}

function deleteTask() {
  if (!editingId) return;
  if (!confirm('Delete this task?')) return;
  tasks = tasks.filter(t=>t.id!==editingId);
  saveTasks();
  closeModal();
  renderCurrentTab();
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  editingId = null;
}

document.getElementById('modalOverlay').addEventListener('click', e=>{
  if (e.target===document.getElementById('modalOverlay')) closeModal();
});

